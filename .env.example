NODE_ENV=development
PORT=3001
API_BASE_PATH=/api/v1

MONGO_URI=mongodb://localhost:27017/subackup

# Use long random secrets in production
JWT_ACCESS_SECRET=change_me_change_me_change_me_change_me_
JWT_REFRESH_SECRET=change_me_change_me_change_me_change_me_
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Used to encrypt Postgres connection strings
ENCRYPTION_KEY=change_me_please_use_long_random

# GitHub Actions (pg_dump) optional
# BACKEND_BASE_URL should be your public API root without /api/v1 (example: https://api.example.com)
PUBLIC_BASE_URL=http://localhost:3001
GITHUB_ACTIONS_SHARED_SECRET=change_me_shared_secret
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_WORKFLOW_FILE=pgdump-backup.yml
